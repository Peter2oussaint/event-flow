generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  eventDate DateTime?
  venue     String?
  message   String?
  source    String
  createdAt DateTime @default(now())
}
